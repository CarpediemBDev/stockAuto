# StockAuto Trading Configuration (Local Environment Template)
# ============================================================

# JWT Auth Secret
# 운영/실전 환경에서는 반드시 충분히 긴 난수 문자열로 교체하세요.
JWT_SECRET_KEY=change_me_to_a_long_random_local_secret

# KIS API Key/Secret/Account No are stored per user in the database.
# Configure them in Personal Settings > Trading Environment when using MOCK or REAL mode.

# Telegram Bot Settings (Phase 11)
# 어드민 화면에서 직접 설정하는 경우 비워두셔도 되며, .env 파일로도 설정할 수 있습니다.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_telegram_bot_username_here

# Gemini API Key for AI Sentiment (Phase 21)
GEMINI_API_KEY=your_gemini_api_key_here
