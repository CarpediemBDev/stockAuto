# StockAuto Trading Configuration (Local Environment Template)
# ============================================================

# KIS API Keys
# MOCK 또는 REAL 모드에서만 필요합니다.
# SIMULATED 모드에서는 아래 키가 없어도 정상 작동합니다.
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here
KIS_ACCOUNT_NO=your_account_no_here

# Telegram Bot Settings (Phase 11)
# 어드민 화면에서 직접 설정하는 경우 비워두셔도 되며, .env 파일로도 설정할 수 있습니다.
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_telegram_bot_username_here
