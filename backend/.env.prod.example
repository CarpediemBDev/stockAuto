# StockAuto Production Environment (Real Trading)
# =================================================

# JWT Auth Secret
# Production startup is blocked when this is missing or left as the insecure default.
JWT_SECRET_KEY=change_me_to_a_long_random_production_secret

# KIS API Key/Secret/Account No are stored per user in the database.
# Configure them in Personal Settings > Trading Environment when using MOCK or REAL mode.

# Telegram Bot Settings (Phase 11)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_telegram_bot_username_here

# Gemini API Key for AI Sentiment (Phase 21)
GEMINI_API_KEY=your_gemini_api_key_here
