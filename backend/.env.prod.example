# StockAuto Production Environment (Real Trading)
# =================================================
# TRADE_MODE: SIMULATED | MOCK | REAL
# ⚠️  REAL 모드에서는 실제 돈이 사용됩니다. 키 유출에 각별히 주의하세요.
TRADE_MODE=REAL
APP_ENV=prod

# BROKER_PROVIDER: KIS | TOSS (향후 확장)
BROKER_PROVIDER=KIS

# KIS API Keys (Real Account)
# 발급받으신 실전매매용 키를 입력하세요. 절대로 외부로 유출되지 않도록 주의하십시오.
KIS_APP_KEY=your_real_app_key_here
KIS_APP_SECRET=your_real_app_secret_here
KIS_ACCOUNT_NO=12345678-01
