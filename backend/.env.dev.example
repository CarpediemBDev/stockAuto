# StockAuto Development Environment (Simulated Paper Trading)
# ============================================================
# TRADE_MODE: SIMULATED | MOCK | REAL
TRADE_MODE=SIMULATED
APP_ENV=dev

# BROKER_PROVIDER: KIS | TOSS (향후 확장)
BROKER_PROVIDER=KIS

# KIS API Keys (SIMULATED 모드에서는 불필요)
# MOCK 모드로 전환하려면 모의투자용 키를 입력하세요.
KIS_APP_KEY=your_virtual_app_key_here
KIS_APP_SECRET=your_virtual_app_secret_here
KIS_ACCOUNT_NO=76543210-01
