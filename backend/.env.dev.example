# StockAuto Development Environment (Simulated Paper Trading)
# ============================================================

# JWT Auth Secret
# 운영/실전 환경에서는 반드시 충분히 긴 난수 문자열로 교체하세요.
JWT_SECRET_KEY=change_me_to_a_long_random_dev_secret

# Browser session cookie
# 프론트와 API가 동일한 scheme + registrable domain을 사용해야 Lax 쿠키가 전송됩니다.
REFRESH_COOKIE_SAMESITE=lax
REFRESH_COOKIE_SECURE=false
ALLOWED_ORIGINS=http://dev.mystockauto.local:3000

# KIS Credential Encryption
KIS_CREDENTIAL_MASTER_KEY=

# Redis order-concurrency guard
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_SOCKET_TIMEOUT_SECONDS=2.0

# KIS API Key/Secret/Account No are stored per user in the database.
# Configure them in Personal Settings > Trading Environment when using MOCK or REAL mode.

# Telegram Bot Settings (Phase 11)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_BOT_USERNAME=your_telegram_bot_username_here

# Gemini API Key for AI Sentiment (Phase 21)
GEMINI_API_KEY=your_gemini_api_key_here
